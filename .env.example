# VPS Manager — Environment Configuration
# Copy this file to .env and fill in your values

# ─── Server ────────────────────────────────────────────────────────────────
PORT=5756
NODE_ENV=development

# JWT signing secret — generate with: openssl rand -hex 32
SESSION_SECRET=change_me_to_a_random_secret

# ─── Database ──────────────────────────────────────────────────────────────
# Option A: Full connection string
# DATABASE_URL=postgresql://user:pass@localhost:5432/vpsmanager

# Option B: Individual vars
PGHOST=localhost
PGPORT=5432
PGUSER=vpsmanager
PGPASSWORD=vpsmanager_secret
PGDATABASE=vpsmanager

# ─── Email / SMTP ──────────────────────────────────────────────────────────
# Provider: resend | brevo | none (default: none)
EMAIL_PROVIDER=none

# Sender identity
EMAIL_FROM_NAME=VPS Manager
EMAIL_FROM_ADDRESS=noreply@yourdomain.com

# Resend (https://resend.com) — use if EMAIL_PROVIDER=resend
RESEND_API_KEY=

# Brevo / Sendinblue SMTP — use if EMAIL_PROVIDER=brevo
BREVO_SMTP_USER=
BREVO_SMTP_PASS=

# ─── CORS ──────────────────────────────────────────────────────────────────
# Set to your public domain in production (e.g. https://vps.yourdomain.com)
# Leave blank to allow all origins (development only)
ALLOWED_ORIGIN=
