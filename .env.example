# VPS Manager — Environment Configuration
# Copy this file to .env and fill in your values.
# The installer generates .env automatically — this file is for manual installs.

# ─── Server ────────────────────────────────────────────────────────────────────
PORT=5756

# JWT signing secret — generate a strong value with:
#   openssl rand -hex 32
SESSION_SECRET=change_me_to_a_random_secret

# ─── Database (PostgreSQL) ─────────────────────────────────────────────────────
# Option A: full connection string (takes priority over individual vars below)
# DATABASE_URL=postgresql://vpsmanager:yourpassword@localhost:5432/vpsmanager

# Option B: individual variables (what the installer writes)
PGHOST=localhost
PGPORT=5432
PGUSER=vpsmanager
PGPASSWORD=vpsmanager_secret
PGDATABASE=vpsmanager

# ─── Email / SMTP ─────────────────────────────────────────────────────────────
# Provider: resend | brevo | none
# If "none", password reset codes are printed to the server log instead of emailed.
# Settings saved through the Settings page in the UI take priority over these vars.
EMAIL_PROVIDER=none

# Sender identity
EMAIL_FROM_NAME=VPS Manager
EMAIL_FROM_ADDRESS=noreply@yourdomain.com

# Resend (https://resend.com) — used when EMAIL_PROVIDER=resend
RESEND_API_KEY=

# Brevo / Sendinblue SMTP — used when EMAIL_PROVIDER=brevo
BREVO_SMTP_USER=
BREVO_SMTP_PASS=

# ─── CORS ──────────────────────────────────────────────────────────────────────
# Set to your public domain in production (e.g. https://vps.yourdomain.com).
# Leave blank to allow only the VPS's own IP + port 5756.
ALLOWED_ORIGIN=
