{
  "name": "vps-manager",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client:delayed\"",
    "client": "vite --port 5000",
    "client:delayed": "bash -c 'until curl -sf http://localhost:5756/api/health > /dev/null 2>&1; do sleep 0.4; done && npx vite --port 5000'",
    "server": "tsx watch server/index.ts",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "start": "node dist/server/index.js",
    "setup": "bash install.sh"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.10.0",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/react-query": "^5.96.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/crypto-js": "^4.2.2",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.20.0",
    "@types/ssh2": "^1.15.5",
    "ansi-to-html": "^0.7.2",
    "aos": "^2.3.4",
    "axios": "^1.15.0",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "concurrently": "^9.2.1",
    "cors": "^2.8.6",
    "crypto-js": "^4.2.0",
    "dotenv": "^16.6.1",
    "express": "^4.22.1",
    "framer-motion": "^11.18.2",
    "highlight.js": "^11.11.1",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.468.0",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.5",
    "pg": "^8.20.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.72.1",
    "react-router-dom": "^7.14.0",
    "react-toastify": "^11.0.5",
    "resend": "^6.10.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "ssh2": "^1.17.0",
    "systeminformation": "^5.31.5",
    "tsx": "^4.21.0",
    "zod": "^3.25.76",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/aos": "^3.0.7",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^22.19.17",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.7.0",
    "typescript": "~5.7.2",
    "vite": "^6.4.2"
  }
}
