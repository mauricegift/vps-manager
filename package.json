{
  "name": "vps-manager",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client:delayed\"",
    "client": "vite --port 5000",
    "client:delayed": "bash -c 'until curl -sf http://localhost:5756/api/health > /dev/null 2>&1; do sleep 0.4; done && npx vite --port 5000'",
    "server": "tsx watch server/index.ts",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "start": "node dist/server/index.js",
    "setup": "bash install.sh"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.0",
    "@tailwindcss/vite": "^4.1.11",
    "@tanstack/react-query": "^5.83.0",
    "@types/crypto-js": "^4.2.2",
    "@types/multer": "^2.1.0",
    "@types/pg": "^8.20.0",
    "@types/ssh2": "^1.15.5",
    "ansi-to-html": "^0.7.2",
    "aos": "^2.3.4",
    "axios": "^1.7.9",
    "clsx": "^2.1.1",
    "concurrently": "^9.1.2",
    "cors": "^2.8.5",
    "crypto-js": "^4.2.0",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "framer-motion": "^11.15.0",
    "highlight.js": "^11.11.1",
    "lucide-react": "^0.468.0",
    "multer": "^2.1.1",
    "pg": "^8.20.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.54.2",
    "react-router-dom": "^7.1.5",
    "react-toastify": "^11.0.3",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "ssh2": "^1.17.0",
    "systeminformation": "^5.23.5",
    "tsx": "^4.19.2",
    "zod": "^3.24.1",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@types/aos": "^3.0.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.7",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "~5.7.2",
    "vite": "^6.0.11"
  }
}
